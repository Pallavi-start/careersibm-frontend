{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],

    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,

    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",

    "resolveJsonModule": true,
    "isolatedModules": true,

    "jsx": "react-jsx",

    "baseUrl": ".",

    "paths": {
      "@/*": ["./*"]
    },

    "ignoreDeprecations": "6.0",

    "plugins": [
      {
        "name": "next"
      }
    ]
  },

  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx"
, "app/admin/page.jsx", "app/admin/login/page.jsx", "app/admin/jobs/page.jsx", "app/admin/dashboard/page.jsx", "app/admin/applications/page.jsx", "app/layout.jsx",   ],

  "exclude": [
    "node_modules"
  ]
}